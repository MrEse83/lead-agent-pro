# SerpAPI — get your key at https://serpapi.com
SERPAPI_KEY=your_serpapi_key_here

# Neon PostgreSQL — get your connection string from neon.tech dashboard
DATABASE_URL=postgresql://user:password@host/dbname

# OpenAI — for AI website analysis and outreach generation
OPENAI_API_KEY=your_openai_key_here

# Gmail SMTP — for sending cold emails
# Step 1: Enable 2-step verification on your Google account
# Step 2: Go to Google Account > Security > App Passwords
# Step 3: Generate an app password for "Mail" and paste it below
GMAIL_ADDRESS=yourgmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Your name — appears in the From field of every email
SENDER_NAME=Banny
